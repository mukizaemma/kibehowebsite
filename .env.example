# Copy relevant values into your .env. Resend: https://resend.com/docs/send-with-laravel
MAIL_MAILER=resend
RESEND_API_KEY=

MAIL_FROM_ADDRESS=info@kibeho-magnificat.rw
MAIL_FROM_NAME="Kibeho Magnificat MV Hôtel"

# Team notifications: primary TO + CC
MAIL_NOTIFICATION_TO=info@kibeho-magnificat.rw
MAIL_NOTIFICATION_CC=

# Production: after changing any MAIL_* or RESEND_* value, run:
#   php artisan config:clear && php artisan config:cache
# Verify sending from the server:
#   php artisan mail:test your@email.com
# Resend requires the domain of MAIL_FROM_ADDRESS to be verified in the Resend dashboard.

APP_NAME="Kibeho Magnificat MV Hôtel"

# --- Public site: reservation channel, reviews, WhatsApp (config/hotel_channels.php) ---
# Primary URL for all "Book Now" buttons (channel manager / booking engine):
HOTEL_RESERVATION_URL=
HOTEL_BOOKING_COM_URL=
HOTEL_TRIPADVISOR_LOCATION_ID=
HOTEL_TRIPADVISOR_HOTEL_URL=
HOTEL_TRIPADVISOR_WRITE_REVIEW_URL=
HOTEL_GOOGLE_PLACE_URL=
HOTEL_GOOGLE_MAPS_EMBED_URL=
HOTEL_WHATSAPP_E164=
HOTEL_WHATSAPP_MESSAGE="Hello Kibeho Magnificat MV Hôtel, I would like to enquire about:"
HOTEL_PUBLIC_EMAIL=info@kibeho-magnificat.rw
